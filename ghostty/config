# dynamic config (theme, font, etc.)
config-file = "?~/dotfiles/ghostty/dynamic-config"
config-file = "?~/dotfiles/ghostty/oled"

# behavior
# initial-command = env PATH="/opt/homebrew/bin:$PATH" ~/dotfiles/scripts/tmux-attach.zsh
confirm-close-surface = false
mouse-hide-while-typing = true
quit-after-last-window-closed = true
copy-on-select = clipboard
selection-clear-on-copy = true
window-colorspace = display-p3
window-height = 40
window-width = 204
macos-option-as-alt = true
macos-titlebar-style = tabs
macos-window-shadow = false
window-padding-balance = true
window-save-state = always

# font
font-style-bold = false
font-style-italic = false
font-style-bold-italic = false
font-synthetic-style = false
font-thicken = true

# keybinds
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = cmd+j=text:\x01j
keybind = cmd+k=text:\x01k
